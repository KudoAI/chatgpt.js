{
  "name": "@kudoai/chatgpt.js",
  "version": "4.14.2",
  "description": "A powerful, open source JavaScript library + interactive CLI for ChatGPT",
  "author": {
    "name": "KudoAI & contributors",
    "email": "contact@kudoai.com",
    "url": "https://kudoai.com"
  },
  "homepage": "https://chatgpt.js.org",
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "http://github.com/sponsors/KudoAI"
    }
  ],
  "main": "dist/chatgpt.min.js",
  "files": [
    "dist/",
    "docs/**/*.md"
  ],
  "bin": {
    "chatgpt-js": "dist/terminal/cli.js",
    "chatgpt.js": "dist/terminal/cli.js",
    "chatgpt": "dist/terminal/cli.js",
    "cjs": "dist/terminal/cli.js",
    "gpt": "dist/terminal/cli.js"
  },
  "types": "chatgpt.d.ts",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint . --cache",
    "lint:all": "eslint .",
    "lint:fix": "eslint . --fix --cache",
    "lint:fix-all": "eslint . --fix",
    "translate": "translate-messages",
    "build": "bash utils/build.sh",
    "build:js": "npm run build",
    "build:js-docs": "minify-js docs/assets/js/src docs/assets/js/min --no-mangle",
    "build:docs-js": "npm run build:js-docs",
    "build:css": "scss-to-css . dist",
    "bump:patch": "bash utils/bump.sh patch",
    "bump:feat": "npm run bump:minor",
    "bump:minor": "bash utils/bump.sh minor",
    "bump:major": "bash utils/bump.sh major",
    "publish:patch": "bash utils/bump.sh patch --publish",
    "publish:minor": "bash utils/bump.sh minor --publish",
    "publish:major": "bash utils/bump.sh major --publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KudoAI/chatgpt.js.git"
  },
  "keywords": [
    "agent",
    "ai",
    "api",
    "artificial intelligence",
    "bot",
    "bytedance",
    "chat",
    "chatbot",
    "chatgpt",
    "cli",
    "clientside",
    "cognitivecomputations",
    "conversational ai",
    "dom",
    "frontend",
    "gemini",
    "gemma",
    "genai",
    "generative ai",
    "glm",
    "google ai",
    "gpt",
    "gpt-5",
    "hermes",
    "interactive",
    "javascript",
    "kimi",
    "kudoai",
    "laguna",
    "library",
    "liquid",
    "llama",
    "llm",
    "machine learning",
    "meta",
    "ml",
    "moonshot ai",
    "nemotron",
    "nex",
    "nlp",
    "nous",
    "nvidia",
    "openai",
    "openrouter",
    "owl",
    "poolside",
    "qwen",
    "repl",
    "seedream",
    "tui",
    "typescript",
    "z-ai"
  ],
  "bugs": "https://github.com/KudoAI/chatgpt.js/issues",
  "dependencies": {
    "@kudoai/ai-personas": "^1.13.0",
    "ansi-colors": "^4.1.3",
    "console-table-printer": "^2.16.1",
    "is-unicode-supported": "^2.1.0",
    "node-clipboardy": "^1.0.3",
    "non-latin-locales": "^1.0.1",
    "terminal-kit": "^3.1.2"
  },
  "devDependencies": {
    "@adamlui/minify.js": "^2.5.3",
    "@adamlui/scss-to-css": "^2.4.4",
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@html-eslint/eslint-plugin": "^0.62.0",
    "@html-eslint/parser": "^0.62.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-regexp": "^3.1.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.62.0"
  }
}
