{
  "google": {
    "endpoints": {
      "chat": "https://generativelanguage.googleapis.com/v1beta/models"
    },
    "models": {
      "free": {
        "gemini-3.1-flash-lite-preview:generateContent": { // https://ai.google.dev/gemini-api/docs/models/gemini-3.1-flash-lite
          "dataTypes": { "input": ["audio", "image", "pdf", "text", "video"], "output": ["text"] },
          "date": { "update": "2026-05", "knowledgeCutoff": "2025-01" },
          "strengths": ["coding", "urlContext"],
          "tokenLimit": { "input": 1048576, "output": 65536 }
        }
      }
    },
    "requiresAPIkey": true
  },
